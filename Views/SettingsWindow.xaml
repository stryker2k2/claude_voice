<Window x:Class="claude_voice.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="720" Width="560"
        MinHeight="380" MinWidth="400"
        Background="#1E1E1E"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Settings"
                   Foreground="#9CDCFE" FontFamily="Segoe UI"
                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <!-- Voice label -->
        <TextBlock Grid.Row="1" Text="Voice"
                   Foreground="#D4D4D4" FontFamily="Segoe UI"
                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>

        <!-- Voice dropdown -->
        <ComboBox Grid.Row="2"
                  Style="{StaticResource DarkComboBox}"
                  ItemContainerStyle="{StaticResource DarkComboBoxItem}"
                  ItemsSource="{Binding AvailableVoices}"
                  SelectedItem="{Binding SelectedVoice}"
                  Margin="0,0,0,14">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayName}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <!-- PTT key label -->
        <TextBlock Grid.Row="3" Text="Push-to-Talk Key"
                   Foreground="#D4D4D4" FontFamily="Segoe UI"
                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>

        <!-- PTT key capture box -->
        <Grid Grid.Row="4" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     x:Name="PttKeyBox"
                     Text="{Binding PttKey, Mode=OneWay}"
                     IsReadOnly="True"
                     Background="#252526" Foreground="#D4D4D4" CaretBrush="#D4D4D4"
                     BorderBrush="#3C3C3C" BorderThickness="1"
                     FontFamily="Segoe UI" FontSize="13"
                     Padding="8,6" TextAlignment="Center"
                     Cursor="Hand" ToolTip="Click then press any key"
                     PreviewKeyDown="PttKeyBox_PreviewKeyDown"/>
            <TextBlock Grid.Column="1"
                       Text="  Click the box, then press any key"
                       Foreground="#666666" FontFamily="Segoe UI" FontSize="11"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Wake word label -->
        <TextBlock Grid.Row="5" Text="Wake Word"
                   Foreground="#D4D4D4" FontFamily="Segoe UI"
                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>

        <!-- Wake word input -->
        <Grid Grid.Row="6" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding WakeWord, UpdateSourceTrigger=PropertyChanged}"
                     Background="#252526" Foreground="#D4D4D4" CaretBrush="#D4D4D4"
                     BorderBrush="#3C3C3C" BorderThickness="1"
                     FontFamily="Segoe UI" FontSize="13"
                     Padding="8,6"/>
            <TextBlock Grid.Column="1"
                       Text="  e.g. &quot;hey claude&quot;"
                       Foreground="#666666" FontFamily="Segoe UI" FontSize="11"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Assistant name label -->
        <TextBlock Grid.Row="7" Text="Assistant Name"
                   Foreground="#D4D4D4" FontFamily="Segoe UI"
                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>

        <!-- Assistant name input -->
        <Grid Grid.Row="8" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding AssistantName, UpdateSourceTrigger=PropertyChanged}"
                     Background="#252526" Foreground="#D4D4D4" CaretBrush="#D4D4D4"
                     BorderBrush="#3C3C3C" BorderThickness="1"
                     FontFamily="Segoe UI" FontSize="13"
                     Padding="8,6"/>
            <TextBlock Grid.Column="1"
                       Text="  shown in chat bubbles"
                       Foreground="#666666" FontFamily="Segoe UI" FontSize="11"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Memory label -->
        <TextBlock Grid.Row="9" Text="Memory"
                   Foreground="#D4D4D4" FontFamily="Segoe UI"
                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>

        <!-- Memory controls -->
        <Grid Grid.Row="10" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <CheckBox Grid.Column="0"
                      IsChecked="{Binding EnableMemory}"
                      Content="Remember conversations between sessions"
                      Foreground="#D4D4D4" FontFamily="Segoe UI" FontSize="13"
                      VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Content="Wipe Memory" Command="{Binding WipeMemoryCommand}"
                    Width="110" Height="28"
                    Background="#5A1A1A" Foreground="#D4D4D4"
                    BorderBrush="#8B2222" BorderThickness="1"
                    FontFamily="Segoe UI" FontSize="12"
                    Cursor="Hand" ToolTip="Erase all remembered conversations"/>
        </Grid>

        <!-- Web Search label -->
        <TextBlock Grid.Row="11" Text="Web Search"
                   Foreground="#D4D4D4" FontFamily="Segoe UI"
                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>

        <!-- Web Search toggle -->
        <CheckBox Grid.Row="12"
                  IsChecked="{Binding EnableWebSearch}"
                  Content="Enable web search (uses Anthropic's built-in search, no extra API key)"
                  Foreground="#D4D4D4" FontFamily="Segoe UI" FontSize="13"
                  VerticalAlignment="Center" Margin="0,0,0,14"/>

        <!-- Silence timeout label -->
        <TextBlock Grid.Row="13" Text="Pause Before Sending"
                   Foreground="#D4D4D4" FontFamily="Segoe UI"
                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>

        <!-- Silence timeout slider -->
        <Grid Grid.Row="14" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Slider Grid.Column="0"
                    Minimum="1" Maximum="10"
                    Value="{Binding SilenceTimeout}"
                    TickFrequency="0.5" IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding SilenceTimeout, StringFormat='{}{0:F1} s'}"
                       Foreground="#D4D4D4" FontFamily="Segoe UI" FontSize="13"
                       Width="44" TextAlignment="Right"
                       VerticalAlignment="Center" Margin="10,0,0,0"/>
        </Grid>

        <!-- Silence threshold label -->
        <TextBlock Grid.Row="15" Text="Voice Threshold"
                   Foreground="#D4D4D4" FontFamily="Segoe UI"
                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>

        <!-- Voice threshold slider -->
        <Grid Grid.Row="16" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Slider Grid.Column="0"
                    Minimum="-60" Maximum="-6"
                    Value="{Binding VoiceThresholdDb}"
                    TickFrequency="1" IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding VoiceThresholdDb, StringFormat='{}{0:F0} dB'}"
                       Foreground="#D4D4D4" FontFamily="Segoe UI" FontSize="13"
                       Width="56" TextAlignment="Right"
                       VerticalAlignment="Center" Margin="10,0,0,0"/>
        </Grid>

        <!-- System prompt label -->
        <TextBlock Grid.Row="17" Text="System Prompt"
                   Foreground="#D4D4D4" FontFamily="Segoe UI"
                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>

        <!-- System prompt editor -->
        <TextBox Grid.Row="18"
                 Text="{Binding SystemPrompt, UpdateSourceTrigger=PropertyChanged}"
                 Background="#252526" Foreground="#D4D4D4" CaretBrush="#D4D4D4"
                 BorderBrush="#3C3C3C" BorderThickness="1"
                 FontFamily="Segoe UI" FontSize="13"
                 TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 Padding="8" VerticalContentAlignment="Top"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="19" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Width="80" Height="30" Margin="0,0,8,0"
                    Background="#3C3C3C" Foreground="#D4D4D4"
                    BorderBrush="#555555" BorderThickness="1"
                    FontFamily="Segoe UI" Cursor="Hand"
                    Click="Cancel_Click"/>
            <Button Content="Save" Width="80" Height="30"
                    Background="#0E639C" Foreground="White"
                    BorderThickness="0" FontFamily="Segoe UI"
                    FontWeight="SemiBold" Cursor="Hand"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
