<Window x:Class="claude_voice.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Claude Voice" Height="600" Width="900"
        MinHeight="400" MinWidth="600"
        Background="#1E1E1E">

    <Window.Resources>
        <!-- Scrollbar style: thin, dark -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Top panel: Claude responses -->
            <RowDefinition Height="*"/>
            <!-- Splitter -->
            <RowDefinition Height="5"/>
            <!-- Bottom panel: user input + PTT -->
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════
             TOP PANEL — Claude responses
             ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#252526" Margin="8,8,8,0" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Grid.Row="0"
                           Text="Claude"
                           Foreground="#9CDCFE"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="12,8,12,4"/>

                <!-- Response text -->
                <ScrollViewer Grid.Row="1"
                              x:Name="ClaudeScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="12,0,12,12">
                    <TextBlock x:Name="ClaudeResponseText"
                               Foreground="#D4D4D4"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               TextWrapping="Wrap"
                               Text="Waiting for response..."/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             SPLITTER
             ═══════════════════════════════════════════════════════ -->
        <GridSplitter Grid.Row="1"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#3C3C3C"
                      ShowsPreview="False"/>

        <!-- ═══════════════════════════════════════════════════════
             BOTTOM PANEL — User input
             ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#252526" Margin="8,0,8,8" CornerRadius="6">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Grid.Row="0"
                           Text="You"
                           Foreground="#9CDCFE"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>

                <!-- Editable transcription area -->
                <TextBox Grid.Row="1"
                         x:Name="UserInputText"
                         Background="#1E1E1E"
                         Foreground="#D4D4D4"
                         CaretBrush="#D4D4D4"
                         BorderBrush="#3C3C3C"
                         BorderThickness="1"
                         FontFamily="Segoe UI"
                         FontSize="14"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Padding="8"
                         VerticalContentAlignment="Top"
                         Text="Hold PTT to speak, or type here..."/>

                <!-- Action bar: PTT + Send -->
                <Grid Grid.Row="2" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status label -->
                    <TextBlock x:Name="StatusText"
                               Grid.Column="0"
                               Text="Ready"
                               Foreground="#6A9955"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               VerticalAlignment="Center"/>

                    <!-- PTT button -->
                    <Button x:Name="PttButton"
                            Grid.Column="1"
                            Content="🎤  Hold to Talk"
                            Width="140" Height="34"
                            Margin="0,0,8,0"
                            Background="#3C3C3C"
                            Foreground="#D4D4D4"
                            BorderBrush="#555555"
                            BorderThickness="1"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            Cursor="Hand"
                            PreviewMouseLeftButtonDown="PttButton_MouseDown"
                            PreviewMouseLeftButtonUp="PttButton_MouseUp"/>

                    <!-- Send button -->
                    <Button x:Name="SendButton"
                            Grid.Column="2"
                            Content="Send"
                            Width="80" Height="34"
                            Background="#0E639C"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="SendButton_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
