<Window x:Class="claude_voice.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="340" Width="560"
        MinHeight="280" MinWidth="400"
        Background="#1E1E1E"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Settings"
                   Foreground="#9CDCFE"
                   FontFamily="Segoe UI"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <!-- System prompt label -->
        <TextBlock Grid.Row="1"
                   Text="System Prompt"
                   Foreground="#D4D4D4"
                   FontFamily="Segoe UI"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Margin="0,0,0,6"/>

        <!-- System prompt editor -->
        <TextBox Grid.Row="2"
                 x:Name="SystemPromptBox"
                 Background="#252526"
                 Foreground="#D4D4D4"
                 CaretBrush="#D4D4D4"
                 BorderBrush="#3C3C3C"
                 BorderThickness="1"
                 FontFamily="Segoe UI"
                 FontSize="13"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 Padding="8"
                 VerticalContentAlignment="Top"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Cancel"
                    Width="80" Height="30"
                    Margin="0,0,8,0"
                    Background="#3C3C3C"
                    Foreground="#D4D4D4"
                    BorderBrush="#555555"
                    BorderThickness="1"
                    FontFamily="Segoe UI"
                    Cursor="Hand"
                    Click="Cancel_Click"/>
            <Button Content="Save"
                    Width="80" Height="30"
                    Background="#0E639C"
                    Foreground="White"
                    BorderThickness="0"
                    FontFamily="Segoe UI"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
