<Window x:Class="claude_voice.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="520" Width="560"
        MinHeight="380" MinWidth="400"
        Background="#1E1E1E"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Settings"
                   Foreground="#9CDCFE" FontFamily="Segoe UI"
                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <!-- Voice label -->
        <TextBlock Grid.Row="1" Text="Voice"
                   Foreground="#D4D4D4" FontFamily="Segoe UI"
                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>

        <!-- Voice dropdown -->
        <ComboBox Grid.Row="2"
                  Style="{StaticResource DarkComboBox}"
                  ItemContainerStyle="{StaticResource DarkComboBoxItem}"
                  ItemsSource="{Binding AvailableVoices}"
                  SelectedItem="{Binding SelectedVoice}"
                  Margin="0,0,0,14">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayName}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <!-- PTT key label -->
        <TextBlock Grid.Row="3" Text="Push-to-Talk Key"
                   Foreground="#D4D4D4" FontFamily="Segoe UI"
                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>

        <!-- PTT key capture box -->
        <Grid Grid.Row="4" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     x:Name="PttKeyBox"
                     Text="{Binding PttKey, Mode=OneWay}"
                     IsReadOnly="True"
                     Background="#252526" Foreground="#D4D4D4" CaretBrush="#D4D4D4"
                     BorderBrush="#3C3C3C" BorderThickness="1"
                     FontFamily="Segoe UI" FontSize="13"
                     Padding="8,6" TextAlignment="Center"
                     Cursor="Hand" ToolTip="Click then press any key"
                     PreviewKeyDown="PttKeyBox_PreviewKeyDown"/>
            <TextBlock Grid.Column="1"
                       Text="  Click the box, then press any key"
                       Foreground="#666666" FontFamily="Segoe UI" FontSize="11"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Wake word label -->
        <TextBlock Grid.Row="5" Text="Wake Word"
                   Foreground="#D4D4D4" FontFamily="Segoe UI"
                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>

        <!-- Wake word input -->
        <Grid Grid.Row="6" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding WakeWord, UpdateSourceTrigger=PropertyChanged}"
                     Background="#252526" Foreground="#D4D4D4" CaretBrush="#D4D4D4"
                     BorderBrush="#3C3C3C" BorderThickness="1"
                     FontFamily="Segoe UI" FontSize="13"
                     Padding="8,6"/>
            <TextBlock Grid.Column="1"
                       Text="  e.g. &quot;hey claude&quot;"
                       Foreground="#666666" FontFamily="Segoe UI" FontSize="11"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- System prompt label -->
        <TextBlock Grid.Row="7" Text="System Prompt"
                   Foreground="#D4D4D4" FontFamily="Segoe UI"
                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>

        <!-- System prompt editor -->
        <TextBox Grid.Row="8"
                 Text="{Binding SystemPrompt, UpdateSourceTrigger=PropertyChanged}"
                 Background="#252526" Foreground="#D4D4D4" CaretBrush="#D4D4D4"
                 BorderBrush="#3C3C3C" BorderThickness="1"
                 FontFamily="Segoe UI" FontSize="13"
                 TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 Padding="8" VerticalContentAlignment="Top"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="9" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Width="80" Height="30" Margin="0,0,8,0"
                    Background="#3C3C3C" Foreground="#D4D4D4"
                    BorderBrush="#555555" BorderThickness="1"
                    FontFamily="Segoe UI" Cursor="Hand"
                    Click="Cancel_Click"/>
            <Button Content="Save" Width="80" Height="30"
                    Background="#0E639C" Foreground="White"
                    BorderThickness="0" FontFamily="Segoe UI"
                    FontWeight="SemiBold" Cursor="Hand"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
