<Window x:Class="claude_voice.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude Voice" Icon="../icon.ico" Height="600" Width="900"
        MinHeight="400" MinWidth="600"
        Background="#1E1E1E"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp">

    <Window.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Width"      Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════
             TOP PANEL — Conversation log
             ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#1E1E1E" Margin="8,8,8,0" CornerRadius="6">
            <ScrollViewer x:Name="ClaudeScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="8">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,3">

                                <!-- System note — centred dim italic, no bubble -->
                                <TextBlock Text="{Binding Text}"
                                           HorizontalAlignment="Center"
                                           Foreground="#555555" FontFamily="Segoe UI"
                                           FontSize="11" FontStyle="Italic"
                                           TextWrapping="Wrap" Margin="0,2">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Border CornerRadius="8" Padding="10,7" MaxWidth="680">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"          Value="#252526"/>
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                    <Setter Property="Background"          Value="#0E4C78"/>
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="#9CDCFE" Margin="0,0,0,3"/>
                                            <TextBlock Text="{Binding Text}"
                                                       FontFamily="Segoe UI" FontSize="14"
                                                       Foreground="#D4D4D4" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <!-- Copy button — visible on bubble hover -->
                                        <Button Content="&#xE8C8;"
                                                VerticalAlignment="Top" HorizontalAlignment="Right"
                                                Width="22" Height="22" Padding="0"
                                                FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="#888888" Cursor="Hand"
                                                ToolTip="Copy to clipboard"
                                                Tag="{Binding Text}"
                                                Click="CopyMessage_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             SPLITTER
             ═══════════════════════════════════════════════════════ -->
        <GridSplitter Grid.Row="1"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Background="#3C3C3C" ShowsPreview="False"/>

        <!-- ═══════════════════════════════════════════════════════
             BOTTOM PANEL — User input
             ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#252526" Margin="8,0,8,8" CornerRadius="6">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="You"
                           Foreground="#9CDCFE" FontFamily="Segoe UI"
                           FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>

                <TextBox Grid.Row="1"
                         Text="{Binding UserInputText, UpdateSourceTrigger=PropertyChanged}"
                         Background="#1E1E1E" Foreground="#D4D4D4" CaretBrush="#D4D4D4"
                         BorderBrush="#3C3C3C" BorderThickness="1"
                         FontFamily="Segoe UI" FontSize="14"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Padding="8" VerticalContentAlignment="Top"
                         PreviewKeyDown="InputBox_KeyDown"/>

                <!-- Volume meter -->
                <Grid Grid.Row="2" Margin="0,8,0,0"
                      Visibility="{Binding IsPttEnabled, Converter={StaticResource BoolToVis}}">
                <ProgressBar
                             Value="{Binding MicLevel, Mode=OneWay}"
                             Minimum="0" Maximum="1"
                             Height="18">
                    <ProgressBar.Template>
                        <ControlTemplate TargetType="ProgressBar">
                            <Border Background="#111111" CornerRadius="3">
                                <Grid>
                                    <Rectangle x:Name="PART_Track" Fill="Transparent"/>
                                    <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="3">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#1A5C2A" Offset="0.0"/>
                                                <GradientStop Color="#27AE60" Offset="0.55"/>
                                                <GradientStop Color="#F39C12" Offset="0.78"/>
                                                <GradientStop Color="#E74C3C" Offset="1.0"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </ProgressBar.Template>
                </ProgressBar>
                <TextBlock Text="{Binding MicDb, StringFormat='{}{0:F1} dB'}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontFamily="Segoe UI" FontSize="10"
                           Foreground="White" IsHitTestVisible="False"/>
                </Grid>

                <!-- Action bar -->
                <Grid Grid.Row="3" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status -->
                    <TextBlock Grid.Column="0"
                               Text="{Binding StatusText}"
                               Foreground="{Binding StatusBrush}"
                               FontFamily="Segoe UI" FontSize="12"
                               VerticalAlignment="Center"/>

                    <!-- Settings -->
                    <Button Grid.Column="1"
                            Content="&#xE713;" Width="34" Height="34" Margin="0,0,8,0"
                            Background="#3C3C3C" Foreground="#D4D4D4"
                            BorderBrush="#555555" BorderThickness="1"
                            FontFamily="Segoe MDL2 Assets" FontSize="16"
                            Cursor="Hand" ToolTip="Settings"
                            Click="SettingsButton_Click"/>

                    <!-- Wake word toggle -->
                    <Button Grid.Column="2"
                            Content="&#xE720;" Width="34" Height="34" Margin="0,0,8,0"
                            Foreground="#D4D4D4" BorderBrush="#555555" BorderThickness="1"
                            FontFamily="Segoe MDL2 Assets" FontSize="16"
                            Cursor="Hand"
                            IsEnabled="{Binding IsWakeWordEnabled}"
                            ToolTip="{Binding WakeWordTooltip}"
                            Command="{Binding ToggleWakeWordCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="#3C3C3C"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsWakeWordActive}" Value="True">
                                        <Setter Property="Background" Value="#1A6B2A"/>
                                        <Setter Property="BorderBrush" Value="#2ECC71"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Stop speaking -->
                    <Button Grid.Column="3"
                            Content="&#xE71A;" Width="34" Height="34" Margin="0,0,8,0"
                            Foreground="#D4D4D4" BorderBrush="#555555" BorderThickness="1"
                            FontFamily="Segoe MDL2 Assets" FontSize="14"
                            Cursor="Hand" ToolTip="Stop speaking"
                            Command="{Binding StopSpeakingCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="#3C3C3C"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSpeaking}" Value="True">
                                        <Setter Property="Background"   Value="#8B1A1A"/>
                                        <Setter Property="BorderBrush"  Value="#E05252"/>
                                        <Setter Property="Foreground"   Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- PTT -->
                    <Button Grid.Column="4" x:Name="PttButton"
                            Content="&#x1F3A4;  Hold to Talk"
                            Width="140" Height="34" Margin="0,0,8,0"
                            Foreground="#D4D4D4" BorderBrush="#555555" BorderThickness="1"
                            FontFamily="Segoe UI" FontSize="13" Cursor="Hand"
                            IsEnabled="{Binding CanUsePtt}"
                            ToolTip="{Binding PttTooltip}"
                            PreviewMouseLeftButtonDown="PttButton_MouseDown"
                            PreviewMouseLeftButtonUp="PttButton_MouseUp">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="#3C3C3C"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                        <Setter Property="Background" Value="#C02020"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Send -->
                    <Button Grid.Column="5"
                            Content="Send" Width="80" Height="34"
                            Background="#0E639C" Foreground="White"
                            BorderThickness="0" FontFamily="Segoe UI"
                            FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                            Command="{Binding SendCommand}"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
